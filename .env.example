# Database
# Three-tier convention (see docs/dev/rgtools-domain-and-env-setup.md):
#   local (this .env.local, `pnpm dev`) -> Neon `dev` branch  (shared with Preview)
#   dev   (Vercel Preview)              -> Neon `dev` branch
#   prod  (Vercel Production)           -> Neon `production` branch  (LIVE DATA)
# Local must NEVER point at the `production` branch. Always use the POOLED string (host has `-pooler`).
# Verify before pasting: `select username, role from users;` on the target branch.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth host (local only — never deployed; Vercel uses AUTH_TRUST_HOST=true instead)
AUTH_URL=http://localhost:3000

# Auth (NextAuth v5)
AUTH_SECRET=your-random-secret-run-openssl-rand-base64-32

# Google Maps — client-side key (Places autocomplete)
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=AIza...

# Google Maps — server-side key (Distance Matrix API)
GOOGLE_MAPS_SERVER_KEY=AIza...

# SMTP (for ServiceM8 inbox sync)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ServiceM8
SERVICEM8_INBOX_EMAIL=inbox@servicem8.example.com
SERVICEM8_API_KEY=
# Full-access (write-capable) key — required to write the Leads Quality custom field on jobs.
# The read-only SERVICEM8_API_KEY cannot write jobs (403 manage_jobs).
SERVICEM8_API_KEY_FULL=
SERVICEM8_SYNC_SECRET=
SERVICEM8_LEAD_QUALITY_FIELD=
SERVICEM8_WEBHOOK_SECRET=
SERVICEM8_ATTACHMENT_WEBHOOK_URL=https://your-app.example.com/api/servicem8/attachment

# OpenAI (optional staff guidance)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Quote tracking storage
# STORAGE_DRIVER is optional. Use local, r2, or leave unset to auto-select r2 when R2_ACCOUNT_ID is set.
STORAGE_DRIVER=
# LOCAL_STORAGE_DIR is optional; defaults to tmp/quotes.
LOCAL_STORAGE_DIR=tmp/quotes
VIEWER_BASE_URL=https://quotes.royalglass.co.nz

# R2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# Optional local development overrides used when NODE_ENV=development.
# R2_ACCESS_KEY_ID_DEV=
# R2_SECRET_ACCESS_KEY_DEV=
# R2_BUCKET_DEV=

# Public calculator submit endpoint. Comma-separate every browser origin that can host the calculator.
CALCULATOR_ALLOWED_ORIGIN=https://royalglass.co.nz,https://www.royalglass.co.nz,https://rgtools.co.nz,https://www.rgtools.co.nz
# Shared secret for trusted WordPress server-to-server calculator forwards.
CALCULATOR_SUBMIT_SECRET=
TURNSTILE_SECRET=

# Customer estimate email (Resend)
RESEND_API_KEY=
RESEND_FROM="Royal Glass <support@royalglass.co.nz>"
