{
  "name": "rgtools-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --filter @rgtools/web dev",
    "build": "pnpm --filter @rgtools/web build && pnpm --filter @rgtools/catalog build",
    "start": "pnpm --filter @rgtools/web start",
    "lint": "pnpm --filter @rgtools/web lint && pnpm --filter @rgtools/catalog lint",
    "test": "pnpm test:workspace && pnpm --filter @rgtools/web test:run",
    "test:workspace": "vitest --run tests",
    "test:run": "pnpm test",
    "test:integration": "pnpm --filter @rgtools/web test:integration",
    "test:e2e": "pnpm --filter @rgtools/web test:e2e",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "node scripts/migrate-prod.mjs",
    "db:studio": "drizzle-kit studio",
    "seed": "pnpm --filter @rgtools/web seed",
    "seed:production-access": "pnpm --filter @rgtools/web seed:production-access",
    "seed:ps-generator": "pnpm --filter @rgtools/web seed:ps-generator",
    "seed:tracking": "pnpm --filter @rgtools/web seed:tracking",
    "quote:pull": "pnpm --filter @rgtools/web quote:pull",
    "quote:preview": "pnpm --filter @rgtools/web quote:preview",
    "quote:share": "pnpm --filter @rgtools/web quote:share",
    "quote:create": "pnpm --filter @rgtools/web quote:create",
    "servicem8:webhook:register": "pnpm --filter @rgtools/web servicem8:webhook:register",
    "clients:merge-cleanup": "pnpm --filter @rgtools/web clients:merge-cleanup",
    "quotes:client-backfill": "pnpm --filter @rgtools/web quotes:client-backfill",
    "jobcard:list": "tsx jobcard-export/jobcard-list.ts",
    "jobcard:export": "tsx jobcard-export/jobcard-export.ts"
  },
  "devDependencies": {
    "@types/node": "^20",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
